# Copy to .env.private and replace every placeholder before deployment.

# Required administrator account
TA_ADMIN_USERNAME=owner
TA_ADMIN_PASSWORD=

# Configure at least one model provider
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
MINIMAX_API_KEY=
OPENROUTER_API_KEY=

# Optional Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
OPENAI_API_VERSION=

# Service identity and support
TA_PUBLIC_BASE_URL=https://research.example.com
TA_SUPPORT_URL=
TA_SUPPORT_CONTACT=
TA_ENTERPRISE_CONTACT=
TA_SPONSOR_QR_ENABLED=false

# Optional email notifications
RESEND_API_KEY=
FROM_EMAIL=
ADMIN_EMAIL=

# Optional update mirror
TA_UPDATE_MANIFEST_URL=

# Daily report defaults
TA_DAILY_LLM_PROVIDER=deepseek
TA_DAILY_QUICK_MODEL=deepseek-chat
TA_DAILY_DEEP_MODEL=deepseek-chat
