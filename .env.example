# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
MINIMAX_API_KEY=
OPENROUTER_API_KEY=

# Email (Resend — for registration & notifications)
RESEND_API_KEY=
FROM_EMAIL=A股量化系统 <noreply@yourdomain.com>
ADMIN_EMAIL=

# Admin access (set both values before enabling the admin page)
TA_ADMIN_USERNAME=
TA_ADMIN_PASSWORD=

# Local development only. Never enable this in a shared or production deployment.
TA_DEV_MODE=false

# Commercial delivery (optional)
TA_SUPPORT_URL=
TA_SUPPORT_CONTACT=
TA_ENTERPRISE_CONTACT=
TA_SPONSOR_QR_ENABLED=false
TA_UPDATE_MANIFEST_URL=

# Daily reports (optional; defaults to DeepSeek)
TA_DAILY_LLM_PROVIDER=deepseek
TA_DAILY_QUICK_MODEL=deepseek-chat
TA_DAILY_DEEP_MODEL=deepseek-chat
